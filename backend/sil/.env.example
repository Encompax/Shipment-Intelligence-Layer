# ─── StarShip Poller (Phase 1) ────────────────────────────────────────────────
# Legacy shipping system base URL (set to your environment)
STARSHIP_BASE_URL=http://shipping-system.local:180
STARSHIP_USER=your_starship_username
STARSHIP_PASS=your_starship_password
STARSHIP_POLL_INTERVAL_MS=60000

# ─── FedEx Enricher ───────────────────────────────────────────────────────────
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENRICHER_INTERVAL_MS=900000

# ─── Karrio Worker (Phase 2+) ─────────────────────────────────────────────────
# Set ENABLE_KARRIO=1 to activate Karrio worker (Phase 2+)
# Leave disabled until Karrio is deployed
ENABLE_KARRIO=0
KARRIO_API_KEY=
KARRIO_BASE_URL=http://karrio:8000/api
KARRIO_POLL_INTERVAL_MS=300000

# ─── SIL Server ───────────────────────────────────────────────────────────────
SIL_PORT=3001
SIL_HOST=0.0.0.0
SIL_DB_PATH=./db/sil.db
