# ─────────────────────────────────────────────────────────────────────────────
# Ethos Shipment Intelligence — Local/Compose Environment (example)
# Copy to .env and fill in secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Backend
PORT=4000
DATABASE_URL=file:/data/app.db
UPLOAD_DIR=uploads
TENANT_NAME=Client Organization

# Frontend
VITE_API_BASE=/api

# Shipment Intelligence Layer (SIL)
SIL_PORT=3001
SIL_HOST=0.0.0.0
SIL_DB_PATH=/data/sil.db

# ── StarShip Poller (Phase 1)
STARSHIP_BASE_URL=http://starship:180
STARSHIP_USER=your_starship_username
STARSHIP_PASS=your_starship_password
STARSHIP_POLL_INTERVAL_MS=60000

# ── FedEx Enricher
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENRICHER_INTERVAL_MS=900000

# ── Karrio Worker (Phase 2+)
ENABLE_KARRIO=0
KARRIO_API_KEY=
KARRIO_BASE_URL=http://karrio:8000/api
KARRIO_POLL_INTERVAL_MS=300000

# Reverse proxy / domain
ETHOS_DOMAIN=ethos-shipment-intelligence.local
